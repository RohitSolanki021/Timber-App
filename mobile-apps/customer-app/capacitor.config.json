{
  "appId": "com.naturalplylam.customer",
  "appName": "Natural Plylam",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["app.naturalplylam.com"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#10b981",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#10b981"
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#ffffff"
  },
  "ios": {
    "backgroundColor": "#ffffff"
  }
}
